{
  "name": "beh-poznamky",
  "version": "1.0.0",
  "description": "Hlasové poznámky s GPS polohou při běhu – nativní Android aplikace",
  "private": true,
  "scripts": {
    "build": "node scripts/copy-www.js",
    "cap:sync": "npm run build && npx cap sync android",
