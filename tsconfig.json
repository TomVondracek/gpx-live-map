{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "None",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "shared/**/*.ts",
    "app/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "www",
    "android",
    "scripts",
    "capacitor.config.ts"
  ]
}
